# Telegram Bot Configuration
# Для тестирования можно не устанавливать - используется хардкод
# Для продакшена ОБЯЗАТЕЛЬНО установить!
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# Admin IDs (через запятую)
# Для тестирования можно не устанавливать - используется тестовый ID
ADMIN_IDS=123456789,987654321

# Web App Configuration
WEBAPP_URL=https://your-domain.com
PORT=3000

# Debug Mode (set to 'true' for detailed logging)
DEBUG_MODE=false

# Railway Configuration (автоматически)
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_PRIVATE_DOMAIN=

# Environment
NODE_ENV=production